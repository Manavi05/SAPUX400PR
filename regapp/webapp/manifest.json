{
  "_version": "1.73.1",
  "sap.app": {
    "id": "demo.regapp.regapp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",

    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata4/sap/zui_reg_03/srvd_a2x/sap/zui_reg/0001/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },

  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },

  "sap.ui5": {

    "rootView": {
      "viewName": "demo.regapp.regapp.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    },

    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },

    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "demo.regapp.regapp.i18n.i18n"
        }
      },

      "": {
        "type": "sap.ui.model.odata.v4.ODataModel",
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "synchronizationMode": "None",
          "autoExpandSelect": true,
          "groupId": "$auto",
          "updateGroupId": "$auto"
        }
      }
    },

    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },

    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlId": "app",
        "controlAggregation": "pages",
        "viewType": "XML",
        "viewPath": "demo.regapp.regapp.view",
        "async": true
      },

      "routes": [
        {
          "name": "RouteView1",
          "pattern": "",
          "target": "TargetView1"
        }
      ],

      "targets": {
        "TargetView1": {
          "viewName": "View1",
          "viewId": "View1"
        }
      }
    }
  }
}